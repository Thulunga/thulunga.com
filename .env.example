# Thulunga monorepo environment variables
# Copy to .env and fill in real values for your setup.

# Node environment
NODE_ENV=development

# API server config
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CAREERS_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/thulunga?schema=public

# Optional Prisma shadow DB (uncomment if used by your workflow)
# SHADOW_DATABASE_URL=postgresql://user:password@localhost:5432/thulunga_shadow?schema=public
